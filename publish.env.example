# Publish script config — copy to publish.env and edit
# publish.env is gitignored (secrets stay local)

# WordPress API (optional — defaults below)
WORDPRESS_API_URL=https://next.mostafijemon.com/wp-json
NEXT_PUBLIC_SITE_URL=https://mostafij-emon-next.vercel.app

# Git branch to push
GIT_BRANCH=main

# WP আপডেটের পরেও প্রতিবার Vercel redeploy (true = recommended)
ALWAYS_REDEPLOY=true

# লোকাল কোড পরিবর্তন থাকলে অটো commit (true = recommended)
AUTO_COMMIT=true

# Commit message prefix
COMMIT_PREFIX=publish

# Optional: Vercel Deploy Hook (faster than CLI)
# Vercel → Project → Settings → Git → Deploy Hooks → Create
# VERCEL_DEPLOY_HOOK=https://api.vercel.com/v1/integrations/deploy/prj_xxx/yyy
