WORDPRESS_API_URL=https://next.mostafijemon.com/wp-json
NEXT_PUBLIC_SITE_URL=https://mostafijemon.com

# On-demand revalidation — WordPress webhook এই secret দিয়ে /api/revalidate কল করবে
# WP functions.php (ME_REVALIDATE_SECRET) এর সাথে হুবহু মিলতে হবে
REVALIDATE_SECRET=CHANGE_ME_long_random_secret

# Contact form (Formspree) — set here OR in WP Site Settings → Contact Form Endpoint
# NEXT_PUBLIC_FORM_ENDPOINT=https://formspree.io/f/your-form-id

# After custom domain setup on Vercel:
# NEXT_PUBLIC_SITE_URL=https://next.mostafijemon.com
